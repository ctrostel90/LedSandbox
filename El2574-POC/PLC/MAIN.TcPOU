<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1">
  <POU Name="MAIN" Id="{ec1b42ab-7513-44bb-b96c-8c8441242596}" SpecialFunc="None">
    <Declaration><![CDATA[PROGRAM MAIN
VAR
	// --- Sprite source images ---
	Red		   : SpriteSheetAnimationFrames(SpriteSheetFilePath := 'C:\temp\images\red_64x1.png', SpriteWidth := 64, SpriteHeight := 1, TotalSprites := 1, Columns := 1, Rows := 1);
	Background : SpriteSheetAnimationFrames(SpriteSheetFilePath := 'C:\temp\images\rainbow_gradient.png', SpriteWidth := 1000, SpriteHeight := 1, TotalSprites := 1, Columns := 1, Rows := 1);
	white	   : SpriteSheetAnimationFrames(SpriteSheetFilePath := 'C:\temp\images\whitealpha3_32_32.png', SpriteWidth := 32, SpriteHeight := 1, TotalSprites := 1, Columns := 1, Rows := 1);
	shortred   : SpriteSheetAnimationFrames(SpriteSheetFilePath := 'C:\temp\images\shortred_32_32.png', SpriteWidth := 32, SpriteHeight := 1, TotalSprites := 1, Columns := 1, Rows := 1);

	// --- Modulators (scroll/unwrap each source into a 64-pixel output) ---
	ModulateRed		   : Modulate;
	ModulateBackground : Modulate;
	ShortredModulator  : Modulate;
	WhiteModulator	   : Modulate;
	backgroundOffset   : UDINT;
	shortredOffset	   : UDINT;
	whiteOffset		   : UDINT;
	UpdateBackground   : BOOL;
	UpdateShortred	   : BOOL;
	UpdateWhite		   : BOOL;

	// --- Scene compositor ---
	MyScene : Scene;
	lerp	: LerpMixer;
	weight	: LREAL := 0.5;

	// --- Displayable image handles (for scope/HMI monitoring) ---
	SceneImage		  : ITcVnDisplayableImage;
	displayBackground : ITcVnDisplayableImage;
	displayShortred	  : ITcVnDisplayableImage;
	displayWhite	  : ITcVnDisplayableImage;
	displayRed		  : ITcVnDisplayableImage;

	// --- Animation timing ---
	Animate			: BOOL := TRUE;
	AddShortedLayer : BOOL := TRUE;
	ShortredRate	: TON  := (PT := T#60MS);
	AddWhiteLayer	: BOOL := TRUE;
	WhiteRate		: TON  := (PT := T#150MS);
	BackgroundRate	: TON  := (PT := T#80MS);

	// --- Unwrap modes ---
	unwraptype			: UDINT;
	reflect				: ReflectUnwrap;
	RepeatNormal		: RepeatUnwrap;
	Extend				: ExtendUnwrap;
	width, height, x, y : UDINT; // reflect.Sample inputs

	// --- Hardware ---
	LEDStrip   : MatrixImageSerializer(Height := 1, Width := 64, X := 0, Y := 0, FlipX := FALSE, FlipY := FALSE, Rotate := FALSE);
	el2574_ch1 : EL2574_ExtendedMode(TotalPixels := 120);

	// --- Misc ---
	Initialized : BOOL;
	val			: HRESULT;
	format		: TcVnPixelFormat;
END_VAR]]></Declaration>
    <Implementation>
      <ST><![CDATA[_AppInfo.KeepOutputsOnBP:=TRUE;

// ============================================================

// 1. LOAD GUARD — wait until all sprite sheets are ready
// ============================================================
IF NOT white.TryLoad() OR NOT Background.TryLoad() OR NOT shortred.TryLoad() OR NOT Red.TryLoad() THEN
	RETURN;
END_IF

// ============================================================

// 2. ONE-TIME INIT — assign unwrap mode to each modulator

// ============================================================
IF NOT Initialized THEN
	Initialized					 := TRUE;
	ModulateRed.Unwrapper		 := reflect;
	ModulateBackground.Unwrapper := reflect;
	ShortredModulator.Unwrapper	 := reflect;
	WhiteModulator.Unwrapper	 := reflect;
END_IF

// ============================================================

// 3. ANIMATION TICK — advance offsets at each layer's own rate

// ============================================================
ShortredRate(IN := NOT ShortredRate.Q AND Animate);
IF ShortredRate.Q THEN
	shortredOffset := shortredOffset + 1;
	IF shortredOffset >= 64 THEN
		shortredOffset := 0;
	END_IF

	UpdateShortred := TRUE;
END_IF

WhiteRate(IN := NOT WhiteRate.Q AND Animate);
IF WhiteRate.Q THEN
	whiteOffset := whiteOffset + 1;
	IF whiteOffset >= 64 THEN
		whiteOffset := 0;
	END_IF

	UpdateWhite := TRUE;
END_IF

BackgroundRate(IN := NOT BackgroundRate.Q AND Animate);
IF BackgroundRate.Q THEN
	backgroundOffset := backgroundOffset + 1;
	UpdateBackground := TRUE;
END_IF

// ============================================================

// 4. MODULATE — scroll each source into a 64-pixel output frame

// ============================================================
IF UpdateBackground THEN
	ModulateBackground.GetImage(Source		 := Background.CurrentFrameImage,
								SourceWidth	 := 1000,
								SourceHeight := 1,
								OutputWidth	 := 120,
								OutputHeight := 1,
								OffsetX		 := backgroundOffset,
								OffsetY		 := 0);

	UpdateBackground := FALSE;
END_IF

IF UpdateShortred THEN
	ShortredModulator.GetImage(shortred.CurrentFrameImage,
							   32,
							   1, // source size
							   120,
							   1, // output size
							   shortredOffset,
							   0);

	UpdateShortred := FALSE;
END_IF

IF UpdateWhite THEN
	WhiteModulator.GetImage(white.CurrentFrameImage,
							32,
							1, // source size
							120,
							1, // output size
							whiteOffset,
							0);

	UpdateWhite := FALSE;
END_IF

// ============================================================

// 5. COMPOSE SCENE — stack layers onto background with lerp blend

// ============================================================
IF NOT el2574_ch1.IsBusy THEN
	MyScene.Initalize(ModulateBackground.CurrentFrameImage);
	lerp.Weight := weight;
	
	IF AddShortedLayer THEN
		MyScene.AddLayer(ShortredModulator.CurrentFrameImage, lerp);		
	END_IF

	IF AddWhiteLayer THEN
		MyScene.AddLayer(WhiteModulator.CurrentFrameImage, lerp);		
	END_IF

	
	//ModulateRed.GetImage(Red.CurrentFrameImage,64,1,64,1,0,0);
	//MyScene.Initalize(ModulateRed.CurrentFrameImage);
	
	
	LEDStrip.UpdateImage(MyScene.Image);
	el2574_ch1.TrySendPixelsFromSerializer(LEDStrip);

	// ============================================================

	// 6. COPY TO DISPLAY — push images to HMI/scope handles

	// ============================================================
	val := F_VN_CopyIntoDisplayableImage(MyScene.Image, SceneImage, s_ok);
	val := F_VN_CopyIntoDisplayableImage(ModulateBackground.CurrentFrameImage, displayBackground, s_ok);
	val := F_VN_CopyIntoDisplayableImage(ShortredModulator.CurrentFrameImage, displayShortred, s_ok);
	val := F_VN_CopyIntoDisplayableImage(WhiteModulator.CurrentFrameImage, displayWhite, s_ok);
END_IF

// ============================================================

// 7. UNWRAP MODE SELECT — override unwrapper at runtime via unwraptype

// ============================================================
CASE unwraptype OF
	0:
		// reflect (set in init, no change needed)
		ShortredModulator.Unwrapper:=reflect;	
	1:
		ShortredModulator.Unwrapper := RepeatNormal;
	2:
		ShortredModulator.Unwrapper := Extend;

	3:
		reflect.Sample(width,
					   height,
					   x,
					   y);
END_CASE

el2574_ch1.CyclicCall();]]></ST>
    </Implementation>
  </POU>
</TcPlcObject>