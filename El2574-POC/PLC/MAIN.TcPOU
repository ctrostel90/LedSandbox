<?xml version="1.0" encoding="utf-8"?>
<TcPlcObject Version="1.1.0.1">
  <POU Name="MAIN" Id="{ec1b42ab-7513-44bb-b96c-8c8441242596}" SpecialFunc="None">
    <Declaration><![CDATA[PROGRAM MAIN
VAR
	// --- Sprite source images ---
	Black	   : SpriteSheetAnimationFrames(SpriteSheetFilePath := 'C:\temp\images\black_64x1.png', SpriteWidth := 64, SpriteHeight := 1, TotalSprites := 1, Columns := 1, Rows := 1);
	Red		   : SpriteSheetAnimationFrames(SpriteSheetFilePath := 'C:\temp\images\red_64x1.png', SpriteWidth := 64, SpriteHeight := 1, TotalSprites := 1, Columns := 1, Rows := 1);
	Blue	   : SpriteSheetAnimationFrames(SpriteSheetFilePath := 'C:\temp\images\blue_64x1.png', SpriteWidth := 64, SpriteHeight := 1, TotalSprites := 1, Columns := 1, Rows := 1);
	Green	   : SpriteSheetAnimationFrames(SpriteSheetFilePath := 'C:\temp\images\green_64x1.png', SpriteWidth := 64, SpriteHeight := 1, TotalSprites := 1, Columns := 1, Rows := 1);
	Background : SpriteSheetAnimationFrames(SpriteSheetFilePath := 'C:\temp\images\rainbow_gradient.png', SpriteWidth := 1000, SpriteHeight := 1, TotalSprites := 1, Columns := 1, Rows := 1);
	white	   : SpriteSheetAnimationFrames(SpriteSheetFilePath := 'C:\temp\images\whitealpha3_32_32.png', SpriteWidth := 32, SpriteHeight := 1, TotalSprites := 1, Columns := 1, Rows := 1);
	shortred   : SpriteSheetAnimationFrames(SpriteSheetFilePath := 'C:\temp\images\shortred_32_32.png', SpriteWidth := 32, SpriteHeight := 1, TotalSprites := 1, Columns := 1, Rows := 1);

	// --- Modulators (scroll/unwrap each source into a strip-length output) ---
	ModulateBackground : Modulate(Width := GVL.STRIP_LENGTH);
	ShortredModulator  : Modulate(Width := GVL.STRIP_LENGTH);
	WhiteModulator	   : Modulate(Width := GVL.STRIP_LENGTH);
	backgroundOffset   : UDINT;
	shortredOffset	   : UDINT;
	shortedRollOver	   : UDINT;
	whiteOffset		   : UDINT;
	whiteRollOver	   : UDINT;
	redOffset		   : UDINT;
	blueOffset		   : UDINT;
	greenOffset		   : UDINT;
	UpdateBackground   : BOOL;
	UpdateShortred	   : BOOL;
	UpdateWhite		   : BOOL;
	UpdateRed		   : BOOL;
	UpdateBlue		   : BOOL;
	UpdateGreen		   : BOOL;

	// --- Scene compositor ---
	MyScene : Scene;
	lerp	: LerpMixer;
	weight	: LREAL := 0.85;

	// --- Displayable image handles (for scope/HMI monitoring) ---
	SceneImage		  : ITcVnDisplayableImage;
	displayBackground : ITcVnDisplayableImage;
	displayShortred	  : ITcVnDisplayableImage;
	displayWhite	  : ITcVnDisplayableImage;
	displayRed		  : ITcVnDisplayableImage;
	displayBlue		  : ITcVnDisplayableImage;
	displayGreen	  : ITcVnDisplayableImage;

	// --- Animation timing ---
	Animate			 : BOOL := TRUE;
	AddBlackLayer	 : BOOL := FALSE;
	AnimateBackgroud : BOOL := TRUE;
	AddBackground	 : BOOL := TRUE;
	BackgroundRate	 : TON	:= (PT := T#80MS);
	AddShortedLayer	 : BOOL := TRUE;
	ShortredRate	 : TON	:= (PT := T#200MS);
	AddWhiteLayer	 : BOOL := TRUE;
	WhiteRate		 : TON	:= (PT := T#150MS);
	AddRedLayer		 : BOOL := FALSE;
	AddBlueLayer	 : BOOL := FALSE;
	AddGreenLayer	 : BOOL := FALSE;

	// --- Unwrap modes ---
	unwraptype			: UDINT;
	reflect				: ReflectUnwrap;
	RepeatNormal		: RepeatUnwrap;
	Extend				: ExtendUnwrap;
	width, height, x, y : UDINT; // reflect.Sample inputs

	// --- Hardware ---
	LEDStrip   : MatrixImageSerializer(Height := 1, Width := GVL.STRIP_LENGTH, X := 0, Y := 0, FlipX := FALSE, FlipY := FALSE, Rotate := FALSE);
	el2574_ch1 : EL2574_ExtendedMode(TotalPixels := GVL.STRIP_LENGTH);

	// --- Misc ---
	val	   : HRESULT;
	format : TcVnPixelFormat;
END_VAR]]></Declaration>
    <Implementation>
      <ST><![CDATA[_AppInfo.KeepOutputsOnBP := TRUE;
// 1. LOAD GUARD — wait until all sprite sheets are ready
IF NOT Black.TryLoad() OR NOT Background.TryLoad() OR NOT shortred.TryLoad() OR NOT white.TryLoad() OR NOT Red.TryLoad() OR NOT Blue.TryLoad() OR NOT Green.TryLoad() THEN
	RETURN;
END_IF

// 2. ANIMATION TICK — advance offsets at each layer's own rate
ShortredRate(IN := NOT ShortredRate.Q AND Animate);
IF ShortredRate.Q THEN
	shortredOffset := shortredOffset + 1;
	IF shortredOffset >= shortedRollOver THEN
		shortredOffset := 0;
	END_IF

	UpdateShortred := TRUE;
END_IF

WhiteRate(IN := NOT WhiteRate.Q AND Animate);
IF WhiteRate.Q THEN
	whiteOffset := whiteOffset + 1;
	IF whiteOffset >= whiteRollOver THEN
		whiteOffset := 0;
	END_IF

	UpdateWhite := TRUE;
END_IF

BackgroundRate(IN := NOT BackgroundRate.Q AND Animate AND AnimateBackgroud);
IF BackgroundRate.Q THEN
	backgroundOffset := backgroundOffset + 1;
	UpdateBackground := TRUE;
END_IF

// 3. UNWRAP MODE SELECT — override shortred/white unwrapper at runtime
ModulateBackground.Unwrapper := reflect;
CASE unwraptype OF
	0:
		shortedRollOver				:= 32;
		whiteRollOver				:= 32;
		ShortredModulator.Unwrapper := RepeatNormal;
		WhiteModulator.Unwrapper	:= RepeatNormal;

	1:
		shortedRollOver				:= GVL.STRIP_LENGTH;
		whiteRollOver				:= GVL.STRIP_LENGTH;
		ShortredModulator.Unwrapper := reflect;
		WhiteModulator.Unwrapper	:= reflect;

	2:
		ShortredModulator.Unwrapper := Extend;
		WhiteModulator.Unwrapper	:= Extend;

END_CASE

// 4. MODULATE — scroll each source into a strip-length output frame
IF UpdateBackground OR NOT AnimateBackgroud THEN
	ModulateBackground.GetImage(Source		 := Background.CurrentFrameImage,
								SourceWidth	 := 1000,
								SourceHeight := 1,
								OutputWidth	 := GVL.STRIP_LENGTH,
								OutputHeight := 1,
								OffsetX		 := backgroundOffset,
								OffsetY		 := 0);

	UpdateBackground := FALSE;
END_IF

IF UpdateShortred THEN
	ShortredModulator.GetImage(shortred.CurrentFrameImage,
							   32,
							   1,
							   GVL.STRIP_LENGTH,
							   1,
							   shortredOffset,
							   0);

	UpdateShortred := FALSE;
END_IF

IF UpdateWhite THEN
	WhiteModulator.GetImage(white.CurrentFrameImage,
							32,
							1,
							GVL.STRIP_LENGTH,
							1,
							whiteOffset,
							0);

	UpdateWhite := FALSE;
END_IF

// 5. COMPOSE SCENE — stack layers onto background with lerp blend
IF NOT el2574_ch1.IsBusy THEN
	IF AddBlackLayer THEN
		MyScene.Initalize(Black.CurrentFrameImage);
	END_IF

	IF AddBackground THEN
		MyScene.Initalize(ModulateBackground.CurrentFrameImage);
	END_IF

	lerp.Weight := weight;
	
	IF AddWhiteLayer THEN
		MyScene.AddLayer(WhiteModulator.CurrentFrameImage, lerp);
	END_IF
	
	IF AddShortedLayer THEN
		MyScene.AddLayer(ShortredModulator.CurrentFrameImage, lerp);
	END_IF

	IF AddRedLayer THEN
		MyScene.AddLayer(Red.CurrentFrameImage, lerp);
	END_IF

	IF AddBlueLayer THEN
		MyScene.AddLayer(Blue.CurrentFrameImage, lerp);
	END_IF

	IF AddGreenLayer THEN
		MyScene.AddLayer(Green.CurrentFrameImage, lerp);
	END_IF

	LEDStrip.UpdateImage(MyScene.Image);
	el2574_ch1.TrySendPixelsFromSerializer(LEDStrip);

	// 6. COPY TO DISPLAY — push images to HMI/scope handles
	val := F_VN_CopyIntoDisplayableImage(MyScene.Image, SceneImage, s_ok);
	val := F_VN_CopyIntoDisplayableImage(ModulateBackground.CurrentFrameImage, displayBackground, s_ok);
	val := F_VN_CopyIntoDisplayableImage(ShortredModulator.CurrentFrameImage, displayShortred, s_ok);
	val := F_VN_CopyIntoDisplayableImage(WhiteModulator.CurrentFrameImage, displayWhite, s_ok);
END_IF

el2574_ch1.CyclicCall();]]></ST>
    </Implementation>
  </POU>
</TcPlcObject>